# Discord Configuration
DISCORD_TOKEN=YOUR_DISCORD_TOKEN_HERE
GUILD_ID=YOUR_GUILD_ID_HERE

# Storage Configuration

# --- Windows IIS / HTTP Server ---
# The base URL where your files are accessible
# Point this to the DIRECTORY where files are hosted, not download.php
IIS_BASE_URL=https://download.penguinhosting.host:84

# Optional: Secure Token Secret (if using the secure script)
# Leave empty if just using direct links
# IIS_SECURE_SECRET=hmCrEklaj2EVNHsp9BxU8NDBCY1W1DBq4F30YZjR4vI

# Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=MYSQL_USER_HERE
MYSQL_PASSWORD=MYSQL_USER_HERE
MYSQL_DATABASE=MYSQL_USER_HERE
MYSQL_PORT=3306

# Used to check if file exists on disk instead of HTTP HEAD request
LOCAL_FILE_PATH=D:\FileServer\Download\Server filer\

# Link Expiration Time (in seconds)
# Default: 3600 (1 hour). Use 0 for effectively unlimited (10 years).
LINK_EXPIRATION_SECONDS=3600